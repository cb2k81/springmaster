# springmaster local configuration template
APP_NAME=springmaster
APP_PORT=8080
APP_PROFILE=dev
APP_BASE_PACKAGE=de.cocondo.platform

# Database defaults. Copy this file to .env before enabling DB operations.
APP_DB_HOST=localhost
APP_DB_PORT=3306
APP_DEV_DB_NAME=springmaster
APP_DEV_DB_USER=springmaster
APP_DEV_DB_PASS=springmaster
APP_STAGE_DB_NAME=springmaster_build
APP_STAGE_DB_USER=springmaster
APP_STAGE_DB_PASS=springmaster

APP_CHANGELOG_DIR=src/main/resources/db/changelog
APP_CHANGELOG_MASTER=src/main/resources/db/changelog/db.changelog-master.xml
APP_LIQUIBASE_CONTEXTS=

APP_OPENAPI_PATH=/api-docs
APP_BUILD_REMOTE_DEPLOY_ENABLED=false
APP_DBTOOL_ALLOW_DESTRUCTIVE=false
LOG_LEVEL=INFO
