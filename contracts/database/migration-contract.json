{
  "schema": "springmaster.database-migration-contract.v1",
  "master": "src/main/resources/db/changelog/db.changelog-master.xml",
  "changesDirectory": "src/main/resources/db/changelog/changes",
  "filePattern": "^db\\.changelog-[0-9]{4}-[a-z0-9-]+\\.xml$",
  "changeSetIdPattern": "^[0-9]{4}-[a-z0-9-]+$",
  "requiredAuthorPattern": "^[a-z][a-z0-9-]*$",
  "forbidRunAlways": true,
  "forbidRunOnChange": true,
  "destructiveElementsRequireRollback": ["dropTable", "dropColumn", "delete", "truncateTable", "renameTable", "renameColumn"]
}
